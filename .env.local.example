# Supabase Postgres — pooled connection (use in app API routes)
MZMS__POSTGRES_URL=postgres://...

# Supabase Postgres — direct connection (use in seed script only)
MZMS__POSTGRES_URL_NON_POOLING=postgres://...

# Supabase project URLs and keys
MZMS__SUPABASE_URL=https://xxxx.supabase.co
MZMS__SUPABASE_SERVICE_ROLE_KEY=...
MZMS__SUPABASE_JWT_SECRET=...
MZMS__SUPABASE_ANON_KEY=...
MZMS__SUPABASE_PUBLISHABLE_KEY=...
MZMS__SUPABASE_SECRET_KEY=...

# Public vars (safe to expose to browser)
NEXT_PUBLIC_MZMS__SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_MZMS__SUPABASE_PUBLISHABLE_KEY=...
NEXT_PUBLIC_MZMS__SUPABASE_ANON_KEY=...

# Postgres connection details (set by Vercel integration)
MZMS__POSTGRES_HOST=...
MZMS__POSTGRES_USER=...
MZMS__POSTGRES_PASSWORD=...
MZMS__POSTGRES_DATABASE=...
MZMS__POSTGRES_PRISMA_URL=...
