{
  "name": "mazmatics-stats",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "seed:supabase": "npx tsx src/scripts/seed-supabase.ts",
    "record:social": "npx ts-node --project tsconfig.node.json scripts/record-social-videos.ts",
    "record:social2": "npx ts-node --project tsconfig.node.json scripts/record-social-videos-2.ts",
    "record:social:landscape": "npx ts-node --project tsconfig.node.json scripts/record-social-videos-landscape.ts",
    "remotion:preview": "cd remotion && npx remotion preview src/index.ts",
    "remotion:render:instagram": "cd remotion && npx remotion render src/index.ts MazmaticsInstagram --output ../e2e/social-videos/remotion/mazmatics-instagram.mp4",
    "remotion:render:linkedin": "cd remotion && npx remotion render src/index.ts MazmaticsLinkedIn --output ../e2e/social-videos/remotion/mazmatics-linkedin.mp4"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "d3": "^7.9.0",
    "next": "^15.1.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.170.0",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@jest/globals": "29.7.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "7.4.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "29.5.11",
    "@types/node": "20.11.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/three": "^0.170.0",
    "@types/topojson-client": "^3.1.4",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "eslint": "8.56.0",
    "eslint-config-next": "15.0.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "postcss": "8.4.33",
    "tailwindcss": "^4.2.1",
    "ts-jest": "29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "5.3.3"
  }
}
